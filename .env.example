# ── Nebius inference API (required) ─────────────────────────────────────────
NEBIUS_API_KEY=XXX

# ── MLflow tracking server ───────────────────────────────────────────────────
# Standalone mode (run-airflow-standalone.sh):
MLFLOW_TRACKING_URI=http://localhost:5001
# Docker Compose mode — use the service name instead:
# MLFLOW_TRACKING_URI=http://mlflow:5001

# ── Object Storage / S3 (optional — enables artifact upload in summarize_and_log) ──
# When set, each run directory is mirrored to s3://<S3_BUCKET>/runs/<run-id>/
# and the URI is stored in manifest.json and logged as an MLflow tag (s3_uri).
# S3_ENDPOINT_URL=https://storage.eu-north1.nebius.cloud
# AWS_ACCESS_KEY_ID=XXX          # Nebius Object Storage key ID
# AWS_SECRET_ACCESS_KEY=XXX      # Nebius Object Storage secret key
# S3_BUCKET=my-mlops-runs